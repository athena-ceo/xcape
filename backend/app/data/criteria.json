  "personas": [
    {
      "key": "safety_community",
      "label_fr": "Sécurité de ma communauté", "label_en": "My community's safety",
      "blurb_fr": "Vous partez par crainte pour votre communauté. On se concentre sur la tolérance, la sécurité et les droits.",
      "blurb_en": "You're leaving out of fear for your community. We focus on tolerance, safety and rights.",
      "match": {"reasons": ["discrimination", "safety"], "tags": ["discrimination", "fear"]},
      "weights": {"inclusion": 3, "safety": 2.5, "political_stability": 2, "gender_equality": 1.5, "visa": 1, "language_ease": 1, "cost_of_living": 1, "healthcare": 0.5},
      "ask": ["communities"],
      "filters": ["safety", "inclusion"],
      "custom_criteria": [
        {"label_en": "Safety for my community", "label_fr": "Sécurité pour ma communauté",
         "description": "How safe, accepted and protected the {community} community is for residents — recent trends in hate incidents, legal protections and everyday climate. Cite trusted human-rights / community sources.",
         "per_community": true, "category": "protection", "min": 0.45}
      ]
    },
    {
      "key": "political_exile",
      "label_fr": "Stabilité politique et libertés", "label_en": "Political stability & freedoms",
      "blurb_fr": "Vous fuyez le climat politique. On privilégie la stabilité, les droits et la sécurité.",
      "blurb_en": "You're fleeing the political climate. We prioritise stability, rights and safety.",
      "match": {"reasons": ["politics"], "tags": ["stability"]},
      "weights": {"political_stability": 3, "safety": 2.5, "gender_equality": 1.5, "inclusion": 1, "visa": 1.5, "cost_of_living": 1, "language_ease": 1},
      "ask": [],
      "filters": ["political_stability", "safety"]
    },
    {
